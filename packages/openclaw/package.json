{
  "name": "mindkeeper-openclaw",
  "version": "0.2.13",
  "description": "OpenClaw plugin for mindkeeper: auto-snapshot, diff, and rollback for agent context files",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "mindkeeper",
    "agent",
    "version-control",
    "snapshot",
    "rollback"
  ],
  "homepage": "https://github.com/seekcontext/mindkeeper#readme",
  "bugs": {
    "url": "https://github.com/seekcontext/mindkeeper/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seekcontext/mindkeeper.git",
    "directory": "packages/openclaw"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
